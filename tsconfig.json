{
	"compilerOptions": {
		"jsx": "react-jsx",
		"baseUrl": ".",
		"paths": {
			"@*": [
				"resources/js/*"
			],
			"@components/*": [
				"resources/js/components/*"
			],
			"@lib/*": [
				"resources/js/lib/*"
			],
			"@layouts/*": [
				"resources/js/layouts/*"
			],
			"@pages/*": [
				"resources/js/pages/*"
			],
			"@styles/*": [
				"resources/js/styles/*"
			],
			"@assets/*": [
				"resources/js/assets/*"
			]
		}
	}
}
